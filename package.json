{
  "name": "udlo-notifier",
  "version": "0.2.0",
  "description": "Minimal CLI to wire S3 → Data Cloud UDLO ingestion (Lambda + Secrets Manager + S3 notifications)",
  "keywords": [
    "salesforce",
    "data-cloud",
    "udlo",
    "s3",
    "lambda",
    "ingestion",
    "unstructured",
    "oclif",
    "cli"
  ],
  "license": "MIT",
  "author": "javrrr",
  "type": "module",
  "bin": {
    "udlo-notifier": "./bin/run.js"
  },
  "files": [
    "dist",
    "bin",
    "force-app",
    "sfdx-project.json",
    "LICENSE",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc -p tsconfig.build.json && mkdir -p dist/lambda && cp src/lambda/handler.mjs dist/lambda/handler.mjs",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "prepack": "npm run build"
  },
  "oclif": {
    "bin": "udlo-notifier",
    "commands": "./dist/commands",
    "topicSeparator": " "
  },
  "dependencies": {
    "@aws-sdk/client-iam": "^3.700.0",
    "@aws-sdk/client-lambda": "^3.700.0",
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/client-secrets-manager": "^3.700.0",
    "@aws-sdk/client-sts": "^3.700.0",
    "@aws-sdk/credential-providers": "^3.1034.0",
    "@oclif/core": "^4.8.3",
    "@salesforce/core": "^8.26.3",
    "data-360-sdk": "^0.2.3"
  },
  "devDependencies": {
    "@types/node": "^22",
    "typescript": "^5.7",
    "vitest": "^3"
  },
  "engines": {
    "node": ">=20"
  }
}
