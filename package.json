{
  "name": "udlo-notifier",
  "version": "0.1.0",
  "description": "sf CLI plugin for S3-to-Data-Cloud unstructured data pipeline setup",
  "type": "module",
  "bin": {
    "udlo-notifier": "./bin/run.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "bin", "force-app", "sfdx-project.json"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npm run build && node scripts/e2e-preflight.mjs"
  },
  "oclif": {
    "bin": "udlo-notifier",
    "commands": "./dist/commands",
    "topicSeparator": " "
  },
  "dependencies": {
    "@oclif/core": "^4.8.3",
    "data-360-sdk": "^0.2.3",
    "@aws-sdk/client-iam": "^3.700.0",
    "@aws-sdk/client-lambda": "^3.700.0",
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/client-secrets-manager": "^3.700.0",
    "@aws-sdk/client-sts": "^3.700.0"
  },
  "devDependencies": {
    "@salesforce/core": "^8.26.3",
    "@types/node": "^22",
    "typescript": "^5.7",
    "vitest": "^3"
  },
  "engines": {
    "node": ">=20"
  }
}
