// udlo-notifier pipeline (Graphviz DOT — no npm; install Graphviz CLI only)
// Render:  cd docs && dot -Tsvg architecture.dot -o architecture.svg
digraph {
  graph [fontname="Helvetica", fontsize=11];
  node [fontname="Helvetica", fontsize=10, shape=box, style=rounded];
  edge [fontname="Helvetica", fontsize=9];

  rankdir=TB;

  dev [label="Developer\nlambda:zip + sf udlo setup", shape=folder];

  subgraph cluster_sf {
    label="Salesforce org";
    labelloc=t;
    fontsize=11;

    cap [label="Connected App (Core)\nUDLO_Notifier + JWT cert\nNamed-user JWT off"];
    oauth [label="Browser OAuth :1717\napi + refresh_token + cdp_ingest_api"];
    s3conn [label="Data Cloud: S3 connection\nkeys or AssumeRole → your AWS"];
    udlo [label="Data Cloud: UDLO / UDMO\ntrailing slash e.g. afd360/"];
  }

  subgraph cluster_aws {
    label="Customer AWS";
    labelloc=t;
    fontsize=11;

    bucket [label="S3 bucket\n(data files)", shape=cylinder];
    iamdc [label="IAM user/role\nGetObject / ListBucket\n(see s3/README.md)"];
    secrets [label="Secrets Manager\nconsumer key + PEM"];
    lamrole [label="Lambda role\nlogs only"];
    lambda [label="Lambda (Python)\nevent JSON → Salesforce\nno GetObject"];
  }

  dev -> { cap oauth s3conn udlo secrets lamrole lambda };
  dev -> bucket [label=" S3 event notif "];

  s3conn -> iamdc [label=" Data Cloud uses ", style=dashed];
  iamdc -> bucket [label=" read object bytes "];

  bucket -> lambda [label=" ObjectCreated "];
  lambda -> secrets;
  lambda -> cap [label=" JWT + CDP + beacon "];
}
