{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Principal": {
        "AWS": "arn:aws:iam::SALESFORCE_AWS_ACCOUNT_ID_PLACEHOLDER:root"
      },
      "Action": "sts:AssumeRole",
      "Condition": {
        "StringEquals": {
          "sts:ExternalId": "STS_EXTERNAL_ID_PLACEHOLDER"
        }
      }
    }
  ]
}
